# Copy to `.env` for local Vite / Tauri dev (optional — only set what you need).

# Optional display metadata (not required unless you read them in the UI later)
# VITE_APP_NAME=FlowManga
# VITE_APP_VERSION=2.2.0

# Optional session cookie for scraper requests that need an authenticated browser session.
# Use only on sites you are permitted to access; never commit real secrets.
# VITE_COMIX_COOKIE="session=..."
