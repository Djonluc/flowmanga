{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "FlowManga",
  "version": "2.5.6",
  "identifier": "com.djonstnix.flowmanga",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run vite",
    "beforeBuildCommand": "npm run vite-build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "FlowManga",
        "width": 2049,
        "height": 1045,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "zoomHotkeysEnabled": true
      }
    ],
    "security": {
      "csp": "default-src 'self' customprotocol: asset: flowmanga:; connect-src 'self' ipc: http://ipc.localhost https: flowmanga:; img-src 'self' asset: flowmanga: https: data: blob:; media-src 'self' asset: flowmanga: https: blob:; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self'; frame-src https:; object-src 'none'; base-uri 'self'; form-action 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../assets/audio/**/*"
    ]
  },
  "plugins": {
    "cli": {
      "description": "FlowManga CLI",
      "args": [
        {
          "name": "path",
          "index": 1,
          "description": "Path to a folder or file to open",
          "takesValue": true
        }
      ]
    }
  }
}
