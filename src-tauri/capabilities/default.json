{
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "*"
  ],
  "permissions": [
    {
      "identifier": "fs:scope",
      "allow": [
        "$HOME/**",
        "$PICTURES/**",
        "$DOWNLOADS/**",
        "$DOCUMENTS/**",
        "$DESKTOP/**"
      ]
    },
    "core:default",
    "sql:default",
    "fs:default",
    "http:default",
    "dialog:default",
    "shell:default",
    "log:default",
    "cli:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "sql:allow-close",
    "fs:allow-exists",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-read-dir",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-write-text-file",
    "dialog:allow-open",
    "shell:allow-open",
    "core:window:allow-set-fullscreen",
    "core:window:allow-maximize",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:webview:allow-set-webview-zoom"
  ]
}